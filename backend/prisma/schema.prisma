generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  username     String    @unique
  streams      Stream[]
  avatarFileId String?
  createdAt    DateTime  @default(now())
  messages     Message[]
  files        File[]
  following    Follow[]  @relation("follower")
  followers    Follow[]  @relation("following")

  @@map("users")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Stream {
  id              String    @id @default(uuid())
  title           String
  description     String?
  isLive          Boolean   @default(false)
  thumbnailFileId String
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  scheduledAt     DateTime
  startedAt       DateTime?
  messages        Message[]
  streamFileId    String?   @unique
  file            File?     @relation(fields: [streamFileId], references: [id])

  @@index([userId])
  @@index([isLive])
  @@index([isLive, scheduledAt])
  @@map("streams")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([streamId, createdAt(sort: Desc)])
  @@map("messages")
}

model File {
  id         String     @id @default(uuid())
  uploaderId String
  key        String     @unique
  status     FileStatus @default(PENDING)
  mimeType   String
  size       Int        @default(0)
  createdAt  DateTime   @default(now())
  uploadedAt DateTime?

  stream Stream?
  user   User    @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("files")
}

enum FileStatus {
  PENDING
  COMPLETED
  FAILED
}
