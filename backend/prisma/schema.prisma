generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String   @unique
  streams   Stream[]
  createdAt DateTime @default(now())

  @@map("users")
}

model Stream {
  id           String   @id @default(uuid())
  title        String
  description  String?
  isLive       Boolean  @default(false)
  thumbnailUrl String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([isLive])
  @@map("streams")
}
